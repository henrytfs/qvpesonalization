NEXT_PUBLIC_APP_URL=https://customize.quaviet.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy public key fallback if publishable keys are not yet configured.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this in browser code.
SUPABASE_SECRET_KEY=your-secret-key

# Legacy server key fallback.
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_STORAGE_BUCKET_UPLOADS=customer-uploads
SUPABASE_STORAGE_BUCKET_OUTPUTS=render-outputs
ADMIN_EMAILS=
INTERNAL_API_SECRET=
